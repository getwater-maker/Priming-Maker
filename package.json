{
  "name": "priming",
  "productName": "Priming",
  "version": "0.2.62",
  "description": "롱폼(16:9)·쇼츠(9:16) 통합 영상 제작 — 대본(.md) → TTS → 이미지/영상 → Vrew(.vrew) 자동 제작 (PrimingFlow + Shots-maker 통합)",
  "main": "bootstrap.js",
  "author": "getwater",
  "scripts": {
    "start": "vite build && electron .",
    "build:renderer": "vite build",
    "dev:renderer": "vite",
    "test:parser": "node test/parser.test.js",
    "test:book": "node test/book-parser.test.js && node test/book-pdf.smoke.js && node test/book-multi.smoke.js && node test/book-ui.smoke.js",
    "build:shorts": "node build-shorts.js",
    "pack": "vite build && electron-builder --win --dir",
    "dist": "vite build && electron-builder --win nsis --x64 --publish never",
    "release": "vite build && electron-builder --win nsis --x64 --publish always",
    "update:manifest": "node scripts/gen-manifest.js",
    "update:publish": "vite build && node scripts/gen-manifest.js"
  },
  "dependencies": {
    "@vivliostyle/cli": "^11.0.4",
    "@vivliostyle/core": "^2.43.2",
    "adm-zip": "^0.5.17",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.3.0",
    "markdown-it": "^14.3.0",
    "markdown-it-footnote": "^4.0.0",
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.21"
  },
  "build": {
    "appId": "com.user.priming",
    "productName": "Priming",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "asar": false,
    "files": [
      "**/*",
      "!renderer/src/**/*",
      "!**/*.map",
      "!_*.md",
      "!lora-dataset/**",
      "!output/**",
      "!dist/**",
      "!ace-step/venv/**",
      "!ace-step/test.wav",
      "!qwen-design/venv/**",
      "!qwen-design/test.wav",
      "!**/__pycache__/**",
      "!Ace Step/**",
      "!Wan2.2 I2V/**",
      "!Wan2.7 I2V/**",
      "!kaggle-lora/**",
      "!usage-coach/**"
    ],
    "asarUnpack": [
      "tts/omnivoice-backend/**",
      "node_modules/ffmpeg-static/**",
      "assets/fonts/**"
    ],
    "extraResources": [
      {
        "from": "node_modules/@vivliostyle/cli/node_modules/archiver-utils",
        "to": "app/node_modules/archiver-utils"
      }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "getwater-maker",
        "repo": "Priming-Maker",
        "releaseType": "release"
      }
    ]
  }
}
